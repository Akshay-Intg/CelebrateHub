@* BirthdayPortal.MVC/Views/Shared/_Layout.cshtml *@
@* Place in: BirthdayPortal.MVC → Views → Shared folder *@

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Birthday & Anniversary Portal</title>

    @* Bootstrap 5 CDN *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    @* Bootstrap Icons *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    @* Google Fonts — full weight range for proper visual hierarchy *@
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    @* Custom design system *@
    <link rel="stylesheet" href="~/css/portal.css" asp-append-version="true" />
</head>
<body class="portal-body">

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── Sidebar Navigation ─────────────────────────────────────────────── -->
        <div class="portal-wrapper">
            <nav class="portal-sidebar" id="sidebar">
                <div class="sidebar-brand">
                    <span class="brand-icon">🎂</span>
                    <span class="brand-text">CelebrateHub</span>
                </div>

                <ul class="sidebar-nav">
                    <li>
                        <a asp-controller="Dashboard" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                            <i class="bi bi-grid-1x2"></i> Dashboard
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Employee" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Employee" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                            <i class="bi bi-people"></i> Employees
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Employee" asp-action="Profile"
                           class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Profile" ? "active" : "")">
                            <i class="bi bi-person-circle"></i> My Profile
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Party" asp-action="Index"
                           class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Party" ? "active" : "")">
                            <i class="bi bi-balloon-heart"></i> Party Voting
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Account" asp-action="ChangePassword" class="sidebar-link">
                            <i class="bi bi-key"></i> Change Password
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="sidebar-section">Admin</li>
                        <li>
                            <a asp-controller="Employee" asp-action="Index" class="sidebar-link">
                                <i class="bi bi-person-gear"></i> Manage Employees
                            </a>
                        </li>
                    }
                </ul>

                <div class="sidebar-footer">
                    <div class="user-info">
                        <div class="user-avatar">@User.Identity.Name?.Substring(0, 1).ToUpper()</div>
                        <div>
                            <div class="user-name">@User.Identity.Name</div>
                            <div class="user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                        </div>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="btn btn-sm btn-outline-danger mt-2 w-100">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </nav>

            <!-- ── Main Content ────────────────────────────────────────────────── -->
            <main class="portal-main">
                <div class="portal-topbar">
                    <button class="btn btn-sm btn-outline-secondary" id="sidebarToggle">
                        <i class="bi bi-list"></i>
                    </button>
                    <h5 class="mb-0 ms-3">@ViewData["Title"]</h5>
                    <span class="ms-auto small text-muted d-none d-sm-inline-flex align-items-center gap-1"
                          style="background: var(--c-ink-50); padding: 0.35rem 0.8rem; border-radius: var(--r-pill); border: 1px solid var(--c-ink-200);">
                        <i class="bi bi-calendar3"></i> @DateTime.Today.ToString("dddd, MMMM dd yyyy")
                    </span>
                </div>

                @* Global alerts *@
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mx-3 mt-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mx-3 mt-3" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="portal-content fade-in-up">
                    @RenderBody()
                </div>
                @await RenderSectionAsync("Modals", required: false)
            </main>
        </div>
    }
    else
    {
        @* Auth pages: no sidebar *@
        <div class="auth-wrapper">
            @RenderBody()
        </div>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/portal.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Party reminder popup — only injected for authenticated users *@
    @if (User.Identity?.IsAuthenticated == true)
    {
        <partial name="_PartyReminderPopup" />
    }

</body>
</html>
