@* BirthdayPortal.MVC/Views/Account/ChangePassword.cshtml *@
@model CelebrateHubMVC.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password"; Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-0 pt-4 px-4">
                <h5 class="mb-0"><i class="bi bi-key me-2 text-primary"></i>Change Password</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    @* <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label required"></label>
                        <input asp-for="CurrentPassword" class="form-control" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div> *@
                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label required"></label>
                        <div class="input-group">
                            <input asp-for="CurrentPassword" class="form-control" />
                            <button type="button" class="btn btn-outline-secondary" id="toggleCurrentPassword">
                                <i class="bi bi-eye" id="currentPasswordEye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    @* <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label required"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div> *@
                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label required"></label>
                        <div class="input-group">
                            <input asp-for="NewPassword" class="form-control" />
                            <button type="button" class="btn btn-outline-secondary" id="toggleNewPassword">
                                <i class="bi bi-eye" id="newPasswordEye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    @* <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label required"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div> *@
                    <div class="mb-4">
                        <label asp-for="ConfirmNewPassword" class="form-label required"></label>
                        <div class="input-group">
                            <input asp-for="ConfirmNewPassword" class="form-control" />
                            <button type="button" class="btn btn-outline-secondary" id="toggleConfirmNewPassword">
                                <i class="bi bi-eye" id="confirmNewPasswordEye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Update Password
                        </button>
                        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function setupPasswordToggle(buttonId, inputId, iconId) {
            $('#' + buttonId).click(function () {
                const input = $('#' + inputId);
                const icon = $('#' + iconId);

                if (input.attr('type') === 'password') {
                    input.attr('type', 'text');
                    icon.removeClass('bi-eye').addClass('bi-eye-slash');
                } else {
                    input.attr('type', 'password');
                    icon.removeClass('bi-eye-slash').addClass('bi-eye');
                }
            });
        }

        setupPasswordToggle('toggleCurrentPassword', 'CurrentPassword', 'currentPasswordEye');
        setupPasswordToggle('toggleNewPassword', 'NewPassword', 'newPasswordEye');
        setupPasswordToggle('toggleConfirmNewPassword', 'ConfirmNewPassword', 'confirmNewPasswordEye');
    </script>
}
