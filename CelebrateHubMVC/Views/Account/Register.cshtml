                document.addEventListener("DOMContentLoaded", function () {

            const today = new Date();

            const maxDob = new Date(
                today.getFullYear() - 18,
                today.getMonth(),
                today.getDate()
            );

            flatpickr("#DateOfBirth", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "F j, Y",
                allowInput: false,
                minDate: "1950-01-01",
                maxDate: maxDob
            });

            flatpickr("#AnniversaryDate", {
                dateFormat: "Y-m-d",
                altInput: true,
                altFormat: "F j, Y",
                allowInput: false
            });

        });





                $('#togglePassword').click(function () {
            const pwd = $('#Password');
            const eye = $('#passwordEye');

            if (pwd.attr('type') === 'password') {
                pwd.attr('type', 'text');
                eye.removeClass('bi-eye').addClass('bi-eye-slash');
            } else {
                pwd.attr('type', 'password');
                eye.removeClass('bi-eye-slash').addClass('bi-eye');
            }
        });

        $('#toggleConfirmPassword').click(function () {
            const pwd = $('#ConfirmPassword');
            const eye = $('#confirmPasswordEye');

            if (pwd.attr('type') === 'password') {
                pwd.attr('type', 'text');
                eye.removeClass('bi-eye').addClass('bi-eye-slash');
            } else {
                pwd.attr('type', 'password');
                eye.removeClass('bi-eye-slash').addClass('bi-eye');
            }
        });
    </script>
}

