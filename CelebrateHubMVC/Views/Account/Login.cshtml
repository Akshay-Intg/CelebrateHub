@* BirthdayPortal.MVC/Views/Account/Login.cshtml *@
@model CelebrateHubMVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In"; Layout = "_Layout";
}

<div class="auth-card">
    <div class="auth-card-left">
        <div class="auth-brand">
            <div class="brand-emoji">🎂</div>
            <h2>Birthday &amp; Anniversary Portal</h2>
            <p>Never miss a celebration at your workplace.</p>
        </div>
        <div class="auth-features">
            <div class="auth-feature"><span>🎉</span> Today's birthday alerts</div>
            <div class="auth-feature"><span>💐</span> Anniversary reminders</div>
            <div class="auth-feature"><span>📅</span> Upcoming celebrations</div>
            <div class="auth-feature"><span>👥</span> Employee directory</div>
        </div>
    </div>

    <div class="auth-card-right">
        <h3 class="mb-1">Welcome back</h3>
        <p class="text-muted mb-4">Sign in to your account</p>

        <form asp-action="Login" method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

            @if (Context.Request.Query["expired"] == "true")
            {
                <div class="alert alert-warning py-2 small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Your session expired. Please sign in again.
                </div>
            }

            <div class="mb-3">
                <label asp-for="Email" class="form-label required"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="you@company.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label required"></label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                    <button class="btn btn-outline-secondary" type="button" id="togglePass">
                        <i class="bi bi-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>

            <hr class="my-3" />
            <p class="text-center mb-0 small">
                Don't have an account?
                <a asp-action="Register" class="text-decoration-none fw-medium">Register here</a>
            </p>

            @* <div class="mt-3 p-2 bg-light rounded small text-muted">
                <strong>Demo:</strong> admin@portal.com / Admin@123
            </div> *@
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $('#togglePass').click(function () {
            const pwd = $('input[name=Password]');
            const eye = $('#eyeIcon');
            if (pwd.attr('type') === 'password') {
                pwd.attr('type', 'text');
                eye.removeClass('bi-eye').addClass('bi-eye-slash');
            } else {
                pwd.attr('type', 'password');
                eye.removeClass('bi-eye-slash').addClass('bi-eye');
            }
        });
    </script>
}
