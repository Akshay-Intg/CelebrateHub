@{ ViewData["Title"] = "Access Denied"; Layout = "_Layout"; }

<div class="row justify-content-center mt-5">
    <div class="col-md-6 text-center">
        <div class="card portal-card p-5">
            <div style="font-size: 4rem;">🚫</div>
            <h4 class="mt-3 mb-2">Access Denied</h4>
            <p class="text-muted mb-4">
                You don't have permission to view this page.
                This area is restricted to your own profile only.
            </p>
            <div class="d-flex gap-2 justify-content-center">
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-grid-1x2 me-1"></i>Go to Dashboard
                </a>
                <a asp-controller="Employee" asp-action="Profile" class="btn btn-outline-secondary">
                    <i class="bi bi-person-circle me-1"></i>My Profile
                </a>
            </div>
        </div>
    </div>
</div>
