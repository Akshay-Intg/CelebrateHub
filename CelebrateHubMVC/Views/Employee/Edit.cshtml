@* BirthdayPortal.MVC/Views/Employee/Edit.cshtml *@
@model CelebrateHubMVC.Models.EditEmployeeViewModel
@{
    ViewData["Title"] = "Edit Profile"; Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card portal-card">
            <div class="card-header portal-card-header">
                <h6 class="mb-0"><i class="bi bi-pencil me-2 text-primary"></i>Edit Employee Profile</h6>
            </div>
            <div class="card-body p-4">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="EmployeeId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label required"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label">Department</label>
                            <input asp-for="Department" class="form-control" placeholder="e.g. Engineering" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Email" class="form-label required"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="DateOfBirth" class="form-label required"></label>
                            <input asp-for="DateOfBirth" type="date" class="form-control"
                                   value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AnniversaryDate" class="form-label"></label>
                            <input asp-for="AnniversaryDate" type="date" class="form-control"
                                   value="@(Model.AnniversaryDate?.ToString("yyyy-MM-dd") ?? "")" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Save Changes
                        </button>
                        <a asp-action="Profile" asp-route-id="@Model.EmployeeId" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
