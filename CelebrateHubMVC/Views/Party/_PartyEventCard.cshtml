@* ============================================================
   BirthdayPortal.MVC/Views/Party/_PartyEventCard.cshtml
   Place in: BirthdayPortal.MVC → Views → Party folder
   ============================================================
   Reusable partial — rendered server-side on load AND returned
   by AJAX after a vote to replace the card in-place.
   ============================================================ *@
@using CelebrateHub.Services.DTOs
@model PartyEventDto

@{
    var progressClass = Model.DonePercentage >= 75 ? "bg-success"
                      : Model.DonePercentage >= 50 ? "bg-warning"
                      : "bg-danger";

    var statusClass = Model.IsPartyGiven ? "party-status-given" : "party-status-pending";
    var cardBorderClass = Model.IsPartyGiven ? "border-success" : "";

    var callerIdStr = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "0";
    int callerId = int.Parse(callerIdStr);
    bool isOwnEvent = Model.EmployeeId == callerId;
    bool hasVoted = Model.MyVote != null;
}

<div class="card party-event-card @cardBorderClass h-100"
     data-event-id="@Model.PartyEventId">
    <div class="card-body p-0">

        @* ── Card header ──────────────────────────────────────────────────── *@
        <div class="party-card-header">
            <div class="d-flex align-items-center gap-2">
                <div class="party-avatar">@Model.EmployeeName.Substring(0, 1)</div>
                <div>
                    <div class="fw-semibold party-emp-name">@Model.EmployeeName</div>
                    <div class="small text-muted">@(Model.Department ?? "—")</div>
                </div>
            </div>
            <div class="d-flex flex-column align-items-end gap-1">
                <span class="party-type-badge @(Model.EventType == "Birthday" ? "badge-birthday" : "badge-anniversary")">
                    @(Model.EventType == "Birthday" ? "🎂" : "💐") @Model.EventType
                </span>
                <span class="small text-muted">@Model.EventDate.ToString("MMM dd, yyyy")</span>
            </div>
        </div>

        <div class="px-3 pb-3">

            @* ── Status badge ──────────────────────────────────────────────── *@
            <div class="d-flex justify-content-between align-items-center mb-2">
                <span class="party-status-badge @statusClass">@Model.StatusLabel</span>
                <span class="small text-muted">@Model.TotalVotes vote@(Model.TotalVotes != 1 ? "s" : "")</span>
            </div>

            @* ── Progress bar ──────────────────────────────────────────────── *@
            <div class="party-progress-wrap mb-2">
                <div class="progress party-progress">
                    <div class="progress-bar @progressClass"
                         role="progressbar"
                         style="width: @Model.DonePercentage%"
                         aria-valuenow="@Model.DonePercentage"
                         aria-valuemin="0" aria-valuemax="100">
                    </div>
                </div>
                <div class="party-progress-labels">
                    <span class="text-success fw-semibold">✅ @Model.DonePercentage.ToString("F0")% Done</span>
                    <span class="text-danger fw-semibold">❌ @Model.PendingPercentage.ToString("F0")% Pending</span>
                </div>
            </div>

            @* ── Vote counts ───────────────────────────────────────────────── *@
            <div class="vote-counts mb-3">
                <div class="vote-count-item vote-done">
                    <span class="vote-num">@Model.DoneVotes</span>
                    <span class="vote-lbl">Done</span>
                </div>
                <div class="vote-divider"></div>
                <div class="vote-count-item vote-pending">
                    <span class="vote-num">@Model.PendingVotes</span>
                    <span class="vote-lbl">Pending</span>
                </div>
            </div>

            @* ── Vote buttons ──────────────────────────────────────────────── *@
            @if (isOwnEvent)
            {
                <div class="alert alert-info py-2 mb-0 small text-center">
                    <i class="bi bi-info-circle me-1"></i>This is your event — you cannot vote.
                </div>
            }
            else
            {
                <div class="vote-buttons">
                    <button type="button"
                            class="btn-vote btn-vote-done @(Model.MyVote == "Done" ? "btn-vote-active" : "")"
                            data-event-id="@Model.PartyEventId"
                            data-vote-type="Done"
                            data-already-voted="@hasVoted.ToString().ToLower()">
                        <i class="bi bi-check-circle me-1"></i>
                        @(Model.MyVote == "Done" ? "✔ You voted Done" : "Party Done")
                    </button>
                    <button type="button"
                            class="btn-vote btn-vote-pending @(Model.MyVote == "Pending" ? "btn-vote-active-pending" : "")"
                            data-event-id="@Model.PartyEventId"
                            data-vote-type="Pending"
                            data-already-voted="@hasVoted.ToString().ToLower()">
                        <i class="bi bi-clock me-1"></i>
                        @(Model.MyVote == "Pending" ? "✔ You voted Pending" : "Still Pending")
                    </button>
                </div>
                @if (hasVoted)
                {
                    <div class="text-center mt-2">
                        <small class="text-muted">
                            <i class="bi bi-arrow-repeat me-1"></i>Click any button to change your vote
                        </small>
                    </div>
                }
            }

        </div>
    </div>
</div>
